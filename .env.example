# ── code-obsidian environment ─────────────────────────────────────────────────
# Copy this file to .env and fill in the values
# cp .env.example .env

# Bearer token for MCP authentication from Cowork
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=your-secret-token-here

# SQLite DB path (inside container, mapped to ./data/graph.db on host)
DB_PATH=/app/data/graph.db

# MCP transport: sse (for Cowork/remote) or stdio (for local Claude Code)
MCP_TRANSPORT=sse

# Port the MCP server listens on inside the container
MCP_PORT=8000
